# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ───────────────────────────────────────────────────
# Use a full connection string OR individual fields below
DATABASE_URL=postgresql://postgres:password@localhost:5432/geofence_db

# Individual fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geofence_db
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Individual fields (used if REDIS_URL is not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication ───────────────────────────────────────────────
# All API requests must include: Authorization: Bearer <API_KEY>
API_KEY=your-secret-api-key-change-this

# ── Cache TTL (seconds) ──────────────────────────────────────────
FENCE_CACHE_TTL=300        # 5 minutes — active fence list
DEVICE_STATE_TTL=86400     # 24 hours  — per-device inside/outside state

# ── Webhooks ─────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=5000    # Max ms to wait for webhook HTTP response
WEBHOOK_RETRY_COUNT=3      # Retry attempts on delivery failure

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info             # error | warn | info | debug
